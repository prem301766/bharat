{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a learner on BharatSkillConnect.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "language": { "type": "string", "description": "Preferred regional language" },
        "interests": { "type": "array", "items": { "type": "string" }, "description": "List of skill interests" },
        "enrolledCourses": { "type": "array", "items": { "type": "string" }, "description": "IDs of courses the user is enrolled in" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user joined" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Course": {
      "title": "Skill Course",
      "description": "A course module available on the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique course ID" },
        "title": { "type": "string", "description": "Course title" },
        "description": { "type": "string", "description": "Brief course description" },
        "language": { "type": "string", "description": "Language of instruction" },
        "category": { "type": "string", "description": "Skill category (e.g., Agriculture, Tech, Craft)" },
        "videoUrl": { "type": "string", "description": "URL to the video tutorial" },
        "thumbnail": { "type": "string", "description": "URL to the course thumbnail image" },
        "duration": { "type": "string", "description": "Estimated time to complete" }
      },
      "required": ["title", "language", "category", "videoUrl"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Available skill courses"
    }
  }
}
